% Natural log lookup table for Clingo
% Representation:
%   x = mantissa_scaled * 10^exp10 / 1000
%   mantissa_scaled in [1000, 9990] step 10
%   exp10 in [0, 9]
%   ln_scaled = round(ln(x) * 1000000)

ln_scale(1000000).
mantissa_scale(1000).
mantissa_step(10).
exp10_min(0).
exp10_max(9).

