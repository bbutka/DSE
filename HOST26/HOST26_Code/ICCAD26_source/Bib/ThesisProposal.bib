	doi = {10.1109/TCAD.2019.2960340},
	abstract = {With the globalization of the semiconductor industry, the supply chain is fragmented across geographies, which has resulted in the importing of third-party IP cores in designs. Such third party IP cores have increased concerns about hardware Trojans. To address such concerns, development of an effective Trojan detection methodology is crucial. In this article, we present a low-cost Trojan detection and activation prevention mechanism for high level synthesis. In particular, a particle swarm optimization-based design space exploration method is proposed which is combined with a Trojan detection mechanism to minimize resource requirements. Additionally, a hybrid evolutionary algorithm-based Trojan detection method is formed with a novel vendor allocation procedure to find low-cost solutions. The proposed algorithm is compared with existing methods-based on Pareto and non-Pareto-based evaluations to verify their efficiency. From the experiment results, it has been verified that the proposed algorithm offers defence against Trojans similar to existing algorithms with less hardware overhead.},
	number = {10},
	urldate = {2025-05-07},
	journal = {IEEE Transactions on Computer-Aided Design of Integrated Circuits and Systems},
	author = {Rajmohan, Shathanaa and Ramasubramanian, N. and Naganathan, Nagi},
	month = oct,
	year = {2020},
	pages = {2602--2614},
	annote = {Rajmohan et al. presents a DSE methodology to prevent distributed trojans from activating each other. Specifically, they use particle swarm optimization to determine how many different 3PIP vendors are needed to prevent trojan collusion. They also utilize an original and duplicate version of each circuit, where the vendors between each version also differ, to further ensure that if a trojan activates, the results will be different. This methodology assumes that 3PIPs may be inherently infected or malicious and intends to prevent their activation. This does not work for self-activating trojans and may cost more money than other solutions because you need access to multiple versions of IPs from different vendors.

},
