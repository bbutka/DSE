
@inproceedings{kumar_saha_fpga_2020,
	title = {{FPGA} {Accelerated} {Embedded} {System} {Security} {Through} {Hardware} {Isolation}},
	url = {https://ieeexplore.ieee.org/abstract/document/9358258},
	doi = {10.1109/AsianHOST51057.2020.9358258},
	abstract = {Modern embedded systems include on-chip FPGA along with processors to meet the high computation demand by providing flexibility to users to add custom hardware accelerators. Any confidential or sensitive information may be processed by those custom accelerators or hardware Intellectual Properties (IPs). Existing accelerator usage models in embedded systems do not prevent illegal access to the IPs, which can be a severe security breach. In this paper, we present a hardware-software co-design approach for secured FPGA accelerated embedded system design. Our proposed security framework inherits Mandatory Access Control (MAC) based authentication policies running at software down to hardware accelerators in FPGA. It ensures secured processing of confidential data in the hardware to prevent software originated attacks at hardware IPs and information leaks. We have implemented a prototype of our proposed framework, which shows that it can be easily integrated while designing an embedded system with custom accelerator IPs. The experimental results show that the proposed framework establishes secured hardware execution with a negligible amount of area and performance overhead.},
	urldate = {2024-08-02},
	booktitle = {2020 {Asian} {Hardware} {Oriented} {Security} and {Trust} {Symposium} ({AsianHOST})},
	author = {Kumar Saha, Sujan and Bobda, Christophe},
	month = dec,
	year = {2020},
	keywords = {Access Controls, SoC, Bobda Paper, Domain Isolation},
	pages = {1--6},
	annote = {This paper proposes an architectural security framework using hardware ip management modules that enforce security policies, and a software ip management module which generates and distributes security policies.
},
	file = {IEEE Xplore Full Text PDF:C\:\\Users\\bbutk\\Zotero\\storage\\RY3C8KVY\\Kumar Saha and Bobda - 2020 - FPGA Accelerated Embedded System Security Through Hardware Isolation.pdf:application/pdf},
}

@inproceedings{saha_metrics_2022,
	title = {Metrics for {Assessing} {Security} of {System}-on-{Chip}},
	url = {https://ieeexplore.ieee.org/abstract/document/9839854},
	doi = {10.1109/HOST54066.2022.9839854},
	abstract = {Due to the increasing complexity of modern hetero-geneous System-on-Chips (SoC) and the growing vulnerabilities, security risk assessment and quantification is required to measure the trustworthiness of a SoC. This paper describes a systematic approach to model the security risk of a system for malicious hardware attacks. The proposed method uses graph analysis to assess the impact of an attack and the Common Vulnerability Scoring System (CVSS) is used to quantify the security level of the system. To demonstrate the applicability of the proposed metric, we consider two open source SoC benchmarks with different architectures. The overall risk is calculated using the proposed metric by computing the exploitability and impact of attack on critical components of a SoC.},
	urldate = {2024-08-02},
	booktitle = {2022 {IEEE} {International} {Symposium} on {Hardware} {Oriented} {Security} and {Trust} ({HOST})},
	author = {Saha, Sujan Kumar and Mbongue, Joel Mandebi and Bobda, Christophe},
	month = jun,
	year = {2022},
	keywords = {SoC, Metrics, Bobda Paper, Graph-Based, Vulnerability},
	pages = {113--116},
	annote = {To begin, in {\textbackslash}cite\{saha\}, Saha et al. propose a metric for assessing SoC security based on risk calculations using the common vulnerability scoring system and a user-defined impact. These risks are brought together to calculate system risk by utilizing a graph representation to showcase the interconnections of components.
Their proposed metric, while a good step towards defining SoC system risk, does not explore the additional aspects of system security, such as encryption or access controls.
},
	file = {IEEE Xplore Full Text PDF:C\:\\Users\\bbutk\\Zotero\\storage\\4L6R3LIS\\Saha et al. - 2022 - Metrics for Assessing Security of System-on-Chip.pdf:application/pdf},
}

