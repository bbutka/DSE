	month = nov,
	year = {2014},
	pages = {371--376},
	annote = {In 2014, Stierand et al. presented a method of integrating security into DSE. Here they define security requirements as what attacks shall be prevented across a particular task flow, for example communication from a sensor to a hardware pre-processing task and finally to a software processor. However, it is not clear what security solutions are implemented, and the main results show that their DSE allocated tasks to solutions that were not possible. 
},
	file = {Full Text PDF:C\:\\Users\\bbutk\\Zotero\\storage\\CZEIBPMI\\Stierand et al. - 2014 - Integrating the Security Aspect into Design Space Exploration of Embedded Systems.pdf:application/pdf},
