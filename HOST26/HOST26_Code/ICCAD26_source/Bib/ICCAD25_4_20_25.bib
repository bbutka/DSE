@inproceedings{butka_measuring_2025,
	title = {Measuring the {Security} of {Zero}-{Trust} {Architecture}-based {Systems}-on-{Chip}},
	abstract = {In the rapidly evolving field of System-on-Chip (SoC) design, securing against internal and external attacks has become a major challenge. This is due to the inclusion of thirdparty IPs and the integration of SoCs into embedded systems. Zero-Trust Architectures (ZTAs) offer a new approach to SoC security by implementing a strict ’never trust, always verify’ ideology. This is divergent from current SoC security solutions due to ZTAs requirement to constantly monitor system transactions and implement dynamic, fine-grained access controls. This highlights the need for innovative SoC security frameworks and identifies the ZTA as a viable solution. Thus, this paper bridges the gap between existing SoC security measures and ZTAs by presenting a framework for adopting zero-trust principles specifically tailored for SoCs through a risk assessment. Recognizing the unique requirements of these systems, this framework is structured into three hierarchical levels: component, bus, and system, each detailing its specific zero-trust requirements. Next, based on these requirements, a component-level metric is defined for risk assessment and is used to evaluate an example SoC design. Additionally, the framework includes a detailed rubric to guide system designers in evaluating their designs for zero-trust compliance. To our knowledge, this paper is the first to explore adopting zero-trust principles to enhance SoC security, paving the way for its future implementation in SoC design methodologies.},
	language = {en},
	author = {Butka, Abigail and Bobda, Christophe},
	year = {2025},
	file = {PDF:D\:\\Users\\Abby Butka\\Zotero\\storage\\RWINR3EZ\\Butka and Department - Measuring the Security of Zero-Trust Architecture-based Systems-on-Chip.pdf:application/pdf},
}

