%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% resilience_enc.lp
%% Purpose: Resilience, compromise scenario, and functional
%%          capability analysis — topology-agnostic.
%%
%% Expects (injected as extra_facts by Phase 3 agent):
%%   p1_risk(Asset, Action, Risk)  — per-action base risk from Phase 1
%%   p1_risk(Asset, Risk)          — fallback 2-arg form
%%   p1_security(Component, Level) — Phase 1 security assignment
%%   compromised(Node)             — scenario: node compromised
%%   failed(Node)                  — scenario: node has failed
%%   deployed_pep(FW)              — Phase 2: placed firewall
%%   deployed_ps(PS)               — Phase 2: placed policy server
%%
%% Expects from instance facts (generated by ASPGenerator):
%%   component/1, link/2, domain/2, asset/3, receiver/1, master/1,
%%   service_component/2, service_quorum/2,
%%   policy_server/1, policy_enforcement_point/1,
%%   pep_guards/2, ps_governs_pep/2,
%%   signed_policy/1, on_path/3,
%%   capability/1, capability_criticality/2,
%%   capability_requires_service/2, capability_requires_component/2,
%%   capability_requires_access/4, capability_phase/2
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 1. TOPOLOGY — bidirectional adjacency, failure-aware
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

adjacent(X, Y) :- link(X, Y).
adjacent(X, Y) :- link(Y, X).

active_adjacent(X, Y) :- adjacent(X, Y), not failed(X), not failed(Y).

reachable(X, Y) :- adjacent(X, Y), Y != X.
reachable(X, Z) :- reachable(X, Y), adjacent(Y, Z), Z != X.

active_reachable(X, Y) :- active_adjacent(X, Y), Y != X.
active_reachable(X, Z) :- active_reachable(X, Y), active_adjacent(Y, Z), Z != X.


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 2. BLAST RADIUS — structural (topology-only)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

blast_radius(N, Count) :-
    component(N),
    Count = #count { M : reachable(N, M), M != N }.


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 2b. FIREWALL-AWARE BLAST RADIUS (effective)
%%     Accounts for deployed firewalls blocking propagation.
%%     Effective blast radius <= structural blast radius.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% A firewall blocks traversal to a guarded component when the
% PEP is active and not bypassed.
fw_blocked(X, Y) :-
    active_policy_enforcement_point(FWL),
    not pep_bypassed(FWL),
    active_pep_guards(FWL, Y),
    adjacent(X, Y),
    X != Y.

effective_adjacent(X, Y) :-
    active_adjacent(X, Y),
    not fw_blocked(X, Y).

% Transitive closure under firewall-aware adjacency.
% Z != X prevents self-loops; mutual loops between non-source
% nodes are handled correctly by Clingo's stable-model fixpoint
% semantics (no duplicate atoms, termination guaranteed).
effective_reachable(X, Y) :- effective_adjacent(X, Y).
effective_reachable(X, Z) :- effective_reachable(X, Y), effective_adjacent(Y, Z), Z != X.

effective_blast_radius(N, Count) :-
    component(N), not failed(N),
    Count = #count { M : effective_reachable(N, M), M != N }.


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 3. ASSET OWNERSHIP AND REACHABILITY
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

asset_owner(A, C) :- asset(C, A, _).

% Structural asset reachability (worst-case, ignores FWs/failures).
% Used for blast_radius and structural attack paths.
asset_reachable(N, A) :- asset(N, A, _).
asset_reachable(N, A) :- reachable(N, C), asset(C, A, _), C != N.

% Effective asset reachability (firewall-aware, failure-aware).
% Used for indirect exposure and amplification — does NOT amplify risk
% through paths that are blocked by placed PEPs or failed nodes.
effective_asset_reachable(N, A) :- asset(N, A, _).
effective_asset_reachable(N, A) :- effective_reachable(N, C), asset(C, A, _), C != N.


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 3b. DOMAIN TRUST LEVEL ORDERING
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

domain_level(untrusted, 0).
domain_level(low,       0).
domain_level(normal,    1).
domain_level(privileged,2).
domain_level(high,      3).
domain_level(root,      3).

cross_trust_boundary(DN, DO) :-
    domain_level(DN, LN), domain_level(DO, LO), LN < LO.


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 4. STANDARD EXPOSURE LEVELS  (amplification x10)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Direct exposure: asset on compromised node (base 30 = 3.0x).
% Protection discount reduces this — a compromised component with
% zero_trust + runtime_attestation (discount=7) has factor 30-7=23 (2.3x)
% vs. no_security (discount=0) at full 30 (3.0x).
% Floor at 10 (1.0x) — compromise always has non-zero impact.
direct_exposure(A, N, Factor) :-
    compromised(N), asset(N, A, _),
    protection_discount(N, Disc),
    F0 = 30 - Disc,
    Factor = #max { F0; 10 }.

% Fallback when no protection discount is available (no Phase 1 facts)
direct_exposure(A, N, 30) :-
    compromised(N), asset(N, A, _),
    not protection_discount(N, _).

indirect_exposure_cross(A, N, 20) :-
    compromised(N), domain(N, DN),
    effective_asset_reachable(N, A), asset_owner(A, Owner),
    domain(Owner, DO),
    cross_trust_boundary(DN, DO),
    not asset(N, A, _),
    not protection_discount(Owner, _).

indirect_exposure_same(A, N, 15) :-
    compromised(N), domain(N, DN),
    effective_asset_reachable(N, A), asset_owner(A, Owner),
    domain(Owner, DO),
    not cross_trust_boundary(DN, DO),
    not asset(N, A, _),
    not protection_discount(Owner, _).


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 4b. MODE-AWARE ACCESS RESTRICTION
%%     When Phase 2 p2_mode_allow facts are present, the system
%%     can restrict access based on the active security mode.
%%     If a scenario involves any compromise, the effective mode
%%     is attack_suspected (attested masters only, non-critical IPs).
%%     Unmediated exposure is reduced when the mode-aware policy
%%     would have denied the access even if the PEP were intact.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

has_mode_policy :- p2_mode_allow(_, _, _).

% Infer the effective security mode from scenario state.
% Any compromise → at least attack_suspected.
% PS compromise or safety-critical compromise → attack_confirmed.
scenario_mode(normal) :-
    has_mode_policy,
    not compromised(_).

scenario_mode(attack_suspected) :-
    has_mode_policy,
    compromised(_),
    not ps_compromised_in_scenario,
    not safety_critical_compromised.

scenario_mode(attack_confirmed) :-
    has_mode_policy,
    ps_compromised_in_scenario.
scenario_mode(attack_confirmed) :-
    has_mode_policy,
    safety_critical_compromised.

ps_compromised_in_scenario :- compromised(PS), policy_server(PS).
safety_critical_compromised :- compromised(C), safety_critical(C).

% Access that is denied by the active mode policy.
% If p2_mode_allow(M, C, Mode) is absent for the current mode,
% the master M would not have access to C even without the scenario.
mode_denied_access(M, C) :-
    has_mode_policy,
    master(M), receiver(C),
    scenario_mode(Mode),
    not p2_mode_allow(M, C, Mode).

% Mode-aware unmediated exposure: when PEP is bypassed, only count
% exposures where the active mode policy would have allowed access.
% If mode policy denies the access, the PEP bypass provides no
% additional attack surface — the attacker gains nothing new.
mode_blocked_unmediated(A, M) :-
    has_mode_policy,
    master(M), asset(C, A, _),
    reachable(M, C),
    mode_denied_access(M, C).


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 5. CONTROL PLANE COMPROMISE (generalized)
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

phase2_context_present :- deployed_pep(_).
phase2_context_present :- deployed_ps(_).

active_policy_server(PS) :- deployed_ps(PS).
active_policy_server(PS) :- policy_server(PS), not phase2_context_present.

active_policy_enforcement_point(FWL) :- deployed_pep(FWL).
active_policy_enforcement_point(FWL) :- policy_enforcement_point(FWL), not phase2_context_present.

active_pep_guards(FWL, C) :-
    active_policy_enforcement_point(FWL),
    pep_guards(FWL, C).

active_ps_governs_pep(PS, FWL) :-
    active_policy_server(PS),
    active_policy_enforcement_point(FWL),
    ps_governs_pep(PS, FWL).

ps_compromised(PS) :- compromised(PS), active_policy_server(PS).

pep_bypassed(FWL) :- compromised(FWL), active_policy_enforcement_point(FWL).
pep_bypassed(FWL) :- ps_compromised(PS), active_ps_governs_pep(PS, FWL).

% Unmediated exposure when PEP is bypassed (base 25 = 2.5x).
% Protection discount applied — well-protected targets behind a bypassed
% PEP are still harder to exploit than unprotected ones.
% Mode-aware: only counts exposures the active mode would have allowed.
% Floor at 10 (1.0x).
unmediated_exposure(A, M, Factor) :-
    master(M), pep_bypassed(PEP),
    active_pep_guards(PEP, C), asset(C, A, _),
    not compromised(M),
    not failed(C), not failed(M),
    not mode_blocked_unmediated(A, M),
    protection_discount(C, Disc),
    F0 = 25 - Disc,
    Factor = #max { F0; 10 }.

% Fallback when no protection discount available
unmediated_exposure(A, M, 25) :-
    master(M), pep_bypassed(PEP),
    active_pep_guards(PEP, C), asset(C, A, _),
    not compromised(M),
    not failed(C), not failed(M),
    not mode_blocked_unmediated(A, M),
    not protection_discount(C, _).

% PS failure -> stale policy (factor 12 = 1.2x)
stale_policy_exposure(A, 12) :-
    failed(PS), active_policy_server(PS),
    active_ps_governs_pep(PS, FWL), not failed(FWL),
    active_pep_guards(FWL, C), asset(C, A, _),
    not pep_bypassed(FWL).

% Unsigned-only exposure: all PSes with signed_policy are down,
% only unsigned PSes remain alive (factor 11 = 1.1x)
unsigned_only_exposure(A, 11) :-
    active_policy_server(PS),
    not failed(PS), not compromised(PS),
    not signed_policy(PS),
    0 = #count { PS2 : active_policy_server(PS2),
                       not failed(PS2), not compromised(PS2),
                       signed_policy(PS2) },
    active_pep_guards(_, C), asset(C, A, _).

% PS conflict: at least one PS compromised while another is alive
% (factor 13 = 1.3x)
ps_conflict_exposure(A, 13) :-
    ps_compromised(SomePS),
    active_policy_server(OtherPS), OtherPS != SomePS,
    not failed(OtherPS), not compromised(OtherPS),
    active_pep_guards(_, C), asset(C, A, _).


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 5b. PROTECTION-AWARE EXPOSURE
%%     Reduces indirect exposure for well-protected components.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Base security discount (prevention)
security_discount(C, 5) :- p1_security(C, zero_trust).
security_discount(C, 4) :- p1_security(C, authenticated_encryption).
security_discount(C, 3) :- p1_security(C, dynamic_mac).
security_discount(C, 1) :- p1_security(C, mac).
security_discount(C, 1) :- p1_security(C, basic_access_control).
security_discount(C, 0) :- p1_security(C, no_security).
security_discount(C, 0) :- receiver(C), not p1_security(C, _).

% Realtime detection discount (detection / dwell-time reduction)
realtime_discount(C, 2) :- p1_realtime(C, runtime_attestation).
realtime_discount(C, 2) :- p1_realtime(C, bus_monitor).
realtime_discount(C, 1) :- p1_realtime(C, watchdog).
realtime_discount(C, 0) :- receiver(C), not p1_realtime(C, _).

audit_discount(C, 3) :- audit_capability(C, full_audit).
audit_discount(C, 2) :- audit_capability(C, standard_audit).
audit_discount(C, 1) :- audit_capability(C, minimal_audit).
audit_discount(C, 0) :- receiver(C), not audit_capability(C, _).

% Combined protection discount: security + realtime + audit (capped at 10)
protection_discount(C, D) :-
    security_discount(C, SD),
    realtime_discount(C, RD),
    audit_discount(C, AD),
    D0 = SD + RD + AD,
    D = #min { D0; 10 }.

% Modified cross-trust indirect exposure with protection factor.
% Uses effective_asset_reachable (firewall-aware, failure-aware).
protected_indirect_cross(A, N, AdjFactor) :-
    compromised(N), domain(N, DN),
    effective_asset_reachable(N, A), asset_owner(A, Owner),
    domain(Owner, DO),
    cross_trust_boundary(DN, DO),
    not asset(N, A, _),
    protection_discount(Owner, Disc),
    F0 = 20 - Disc,
    AdjFactor = #max { F0; 10 }.

% Modified same-trust indirect exposure with protection factor.
% Uses effective_asset_reachable (firewall-aware, failure-aware).
protected_indirect_same(A, N, AdjFactor) :-
    compromised(N), domain(N, DN),
    effective_asset_reachable(N, A), asset_owner(A, Owner),
    domain(Owner, DO),
    not cross_trust_boundary(DN, DO),
    not asset(N, A, _),
    protection_discount(Owner, Disc),
    F0 = 15 - Disc,
    AdjFactor = #max { F0; 10 }.


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 6. MAXIMUM AMPLIFICATION
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Amplification factor: max of all active exposure sources.
% Baseline (no compromise/failure) = AMP_DENOM = 10 (1.0x).
% Protection-aware factors CAN go below 10 when discounts apply,
% allowing well-protected assets to show reduced scenario risk.
% The sentinel only fires when NO exposure source is active.
has_exposure(A) :- direct_exposure(A, _, _).
has_exposure(A) :- indirect_exposure_cross(A, _, _).
has_exposure(A) :- indirect_exposure_same(A, _, _).
has_exposure(A) :- protected_indirect_cross(A, _, _).
has_exposure(A) :- protected_indirect_same(A, _, _).
has_exposure(A) :- unmediated_exposure(A, _, _).
has_exposure(A) :- stale_policy_exposure(A, _).
has_exposure(A) :- unsigned_only_exposure(A, _).
has_exposure(A) :- ps_conflict_exposure(A, _).

max_amp_factor(A, Factor) :-
    asset(_, A, _),
    has_exposure(A),
    Factor = #max {
        F    : direct_exposure(A, _, F)          ;
        F    : indirect_exposure_cross(A, _, F)  ;
        F    : indirect_exposure_same(A, _, F)   ;
        F    : protected_indirect_cross(A, _, F) ;
        F    : protected_indirect_same(A, _, F)  ;
        F    : unmediated_exposure(A, _, F)       ;
        F    : stale_policy_exposure(A, F)        ;
        F    : unsigned_only_exposure(A, F)       ;
        F    : ps_conflict_exposure(A, F)
    }.

% Baseline sentinel: no exposure sources active = 1.0x (10)
max_amp_factor(A, 10) :-
    asset(_, A, _),
    not has_exposure(A).


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 7. SCENARIO RISK
%%
%% Risk semantics: WEIGHTED SUM over all (asset, action) pairs,
%% matching the Phase 1 objective.  When p1_risk_weight/2 facts
%% are available (serialized by Phase 1), each risk point is
%% amplified by the asset's topology-derived criticality weight.
%% Without weights, each asset counts equally (weight = 1).
%%
%% This replaces the previous max-over-actions aggregation,
%% which could disagree with Phase 1 on which assets matter most.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% Per-action scenario risk = baseline risk * amplification factor
scenario_action_risk(A, Action, ScenRisk) :-
    p1_risk(A, Action, BaseRisk),
    max_amp_factor(A, Factor),
    ScenRisk = BaseRisk * Factor.

% Helper: asset has 3-arg action-level risk data
has_action_risk(A) :- p1_risk(A, _, _).

% Risk weight: use Phase 1 weight when available, else 1 (uniform).
effective_risk_weight(A, W) :- p1_risk_weight(A, W).
effective_risk_weight(A, 1) :- asset(_, A, _), not p1_risk_weight(A, _).

% Primary path: weighted sum over all (asset, action) scenario risks.
% Matches Phase 1's weighted-sum objective semantics.
scenario_asset_risk(A, ScenRisk) :-
    has_action_risk(A),
    asset(_, A, _),
    effective_risk_weight(A, W),
    ActionSum = #sum { R, Action : scenario_action_risk(A, Action, R) },
    ScenRisk = W * ActionSum.

% Fallback path: use 2-arg p1_risk when no action-level risk exists.
% Fires exclusively -- has_action_risk guard prevents double-counting.
scenario_asset_risk(A, ScenRisk) :-
    p1_risk(A, BaseRisk),
    not has_action_risk(A),
    max_amp_factor(A, Factor),
    effective_risk_weight(A, W),
    ScenRisk = BaseRisk * Factor * W.

% Legacy max-per-asset metric retained for backward-compat diagnostics.
scenario_asset_max_risk(A, MaxRisk) :-
    has_action_risk(A),
    asset(_, A, _),
    MaxRisk = #max { R : scenario_action_risk(A, _, R) ; 0 : asset(_, A, _) }.

scenario_total_risk(Total) :-
    Total = #sum { R, A : scenario_asset_risk(A, R) }.


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 8. SERVICE HEALTH
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

asset_available(A)   :- asset(Owner, A, _), not failed(Owner), not compromised(Owner).
asset_unavailable(A) :- asset(Owner, A, _), failed(Owner).
asset_compromised(A) :- asset(Owner, A, _), compromised(Owner).

% A receiver is cut off only when no master can reach it.
% Previous rule used any node; this is more precise — if at least
% one master can still access C, the node is not operationally cut off.
node_cut_off(C) :-
    receiver(C), not failed(C),
    0 = #count { M : master(M), not failed(M), active_reachable(M, C) }.

service_live_count(S, N) :-
    service_quorum(S, _),
    N = #count { C : service_component(S, C),
                     not failed(C),
                     not compromised(C),
                     not node_cut_off(C) }.

service_ok(S) :-
    service_quorum(S, Q),
    service_live_count(S, N), N >= Q.

service_degraded(S) :-
    service_quorum(S, Q),
    service_live_count(S, N),
    N > 0, N < Q.

service_unavailable(S) :-
    service_quorum(S, _),
    service_live_count(S, 0).

component_bus_cut(C) :-
    receiver(C), not failed(C),
    node_cut_off(C).


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 9. CONTROL PLANE HEALTH
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

active_ps_count(N) :-
    N = #count { PS : active_policy_server(PS), not failed(PS), not compromised(PS) }.

has_healthy_governor(FWL) :-
    active_ps_governs_pep(PS, FWL),
    not failed(PS),
    not ps_compromised(PS).

ungoverned_pep(FWL) :-
    active_policy_enforcement_point(FWL),
    not failed(FWL),
    not has_healthy_governor(FWL).

stale_policy_active :- stale_policy_exposure(_, _).

control_plane_degraded :-
    ungoverned_pep(_).
control_plane_degraded :-
    pep_bypassed(_).
control_plane_degraded :-
    stale_policy_active.

control_plane_compromised :-
    ps_compromised(_).


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 10. ATTACK PATH ENUMERATION
%%     Multi-hop compromise chains from compromised nodes
%%     to safety-critical or high-value targets.
%%
%%     Cycle handling: attack_step prevents revisiting the source
%%     (C != N) and direct predecessor (C != Prev).  Intermediate
%%     revisits are possible on cyclic topologies, but the configured
%%     depth cap
%%     depth bound ensures termination.  min_attack_distance/3
%%     extracts the SHORTEST path, so redundant longer paths do
%%     not affect the reported metric.  This is a deliberate
%%     trade-off: full visited-set tracking requires O(n^d)
%%     auxiliary predicates, which would dominate grounding time
%%     on larger topologies for minimal analytical benefit.
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

attack_depth_limit(MaxD) :- system_capability(max_attack_depth, MaxD), MaxD > 0.
attack_depth_limit(5) :- not system_capability(max_attack_depth, _).

attack_step(N, C, 1) :-
    compromised(N), effective_adjacent(N, C), C != N,
    not failed(C).

attack_step(N, C, D+1) :-
    attack_step(N, Prev, D),
    effective_adjacent(Prev, C),
    not failed(C),
    C != N, C != Prev,
    attack_depth_limit(MaxD),
    D < MaxD.

% Unblocked attack step — ignores firewalls (worst-case structural)
structural_attack_step(N, C, 1) :-
    compromised(N), active_adjacent(N, C), C != N,
    not failed(C).

structural_attack_step(N, C, D+1) :-
    structural_attack_step(N, Prev, D),
    active_adjacent(Prev, C),
    not failed(C),
    C != N, C != Prev,
    attack_depth_limit(MaxD),
    D < MaxD.

attack_reaches_critical(N, C, D) :-
    attack_step(N, C, D),
    safety_critical(C).

attack_reaches_critical(N, C, D) :-
    attack_step(N, C, D),
    critical(C).

escalation_path(N, C, DN, DC) :-
    attack_step(N, C, _),
    domain(N, DN), domain(C, DC),
    cross_trust_boundary(DN, DC).

min_attack_distance(N, C, MinD) :-
    attack_reaches_critical(N, C, _),
    MinD = #min { D : attack_reaches_critical(N, C, D) }.

% Structural (worst-case) attack paths ignoring firewalls
structural_reaches_critical(N, C, D) :-
    structural_attack_step(N, C, D), safety_critical(C).
structural_reaches_critical(N, C, D) :-
    structural_attack_step(N, C, D), critical(C).

structural_min_distance(N, C, MinD) :-
    structural_reaches_critical(N, C, _),
    MinD = #min { D : structural_reaches_critical(N, C, D) }.


%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% 11. FUNCTIONAL RESILIENCE — MISSION CAPABILITY ASSESSMENT
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% A required service is broken if it drops below quorum
% (both unavailable and degraded represent quorum loss)
capability_service_broken(Cap, Svc) :-
    capability_requires_service(Cap, Svc),
    service_unavailable(Svc).

capability_service_broken(Cap, Svc) :-
    capability_requires_service(Cap, Svc),
    service_degraded(Svc).

capability_component_broken(Cap, C) :-
    capability_requires_component(Cap, C),
    failed(C).

capability_component_broken(Cap, C) :-
    capability_requires_component(Cap, C),
    compromised(C).

capability_component_broken(Cap, C) :-
    capability_requires_component(Cap, C),
    node_cut_off(C).

capability_access_broken(Cap, M, C, Op) :-
    capability_requires_access(Cap, M, C, Op),
    failed(C).

capability_access_broken(Cap, M, C, Op) :-
    capability_requires_access(Cap, M, C, Op),
    failed(M).

capability_access_broken(Cap, M, C, Op) :-
    capability_requires_access(Cap, M, C, Op),
    compromised(C).

capability_access_broken(Cap, M, C, Op) :-
    capability_requires_access(Cap, M, C, Op),
    not active_reachable(M, C),
    M != C.

% Access path unmediated — PEP guarding the target is bypassed.
% The access works but with zero policy enforcement (security degraded).
capability_access_unmediated(Cap, M, C, Op) :-
    capability_requires_access(Cap, M, C, Op),
    not capability_access_broken(Cap, M, C, Op),
    active_pep_guards(PEP, C),
    pep_bypassed(PEP).

% Unmediated access degrades the capability (not lost, but insecure)
capability_degraded_by_bypass(Cap) :-
    capability(Cap),
    not capability_lost(Cap),
    capability_access_unmediated(Cap, _, _, _).

capability_lost(Cap) :-
    capability(Cap),
    capability_service_broken(Cap, _).

capability_lost(Cap) :-
    capability(Cap),
    capability_component_broken(Cap, _).

capability_lost(Cap) :-
    capability(Cap),
    capability_access_broken(Cap, _, _, _).

capability_degraded(Cap) :-
    capability_degraded_by_bypass(Cap),
    not capability_lost(Cap).

capability_ok(Cap) :-
    capability(Cap),
    not capability_lost(Cap),
    not capability_degraded(Cap).

capability_ok_count(N) :-
    N = #count { Cap : capability_ok(Cap) }.

capability_degraded_count(N) :-
    N = #count { Cap : capability_degraded(Cap) }.

capability_lost_count(N) :-
    N = #count { Cap : capability_lost(Cap) }.

essential_capability_lost(Cap) :-
    capability_lost(Cap),
    capability_criticality(Cap, essential).

% Only assert system_functional when capabilities are actually defined.
% Without this guard, topologies with no capability facts would
% trivially satisfy "not essential_capability_lost(_)".
has_capabilities :- capability(_).

system_functional :-
    has_capabilities,
    not essential_capability_lost(_).

system_functional :-
    not has_capabilities.

system_degraded :-
    system_functional,
    capability_lost(_).

system_degraded :-
    system_functional,
    capability_degraded(_).

system_non_functional :-
    has_capabilities,
    essential_capability_lost(_).


